def haru_2026_matchup_kimarite() -> dict[tuple[str, str], dict]:
    """Return kimarite frequencies for specific matchups.

    Returns: {(winner_id, loser_id): {"yorikiri": 3, "oshidashi": 1, ...}}
    This reveals HOW a wrestler typically beats a specific opponent.
    """
    return {
        ("abi", "asakoryu"): {"tsukidashi": 1},
        ("abi", "asanoyama"): {"hikiotoshi": 2, "oshitaoshi": 1, "uwatenage": 1},
